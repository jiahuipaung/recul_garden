# EmailJS 配置
# 在 https://www.emailjs.com/ 注册并获取以下凭据
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# 应用配置
VITE_APP_BASE_URL=/
VITE_APP_API_URL=https://your-domain.vercel.app

# 注意：
# 1. 不要提交 .env 文件到 Git（已在 .gitignore 中配置）
# 2. 在 Vercel Dashboard > Project Settings > Environment Variables 中配置实际值
# 3. 所有环境变量必须以 VITE_ 开头才能在前端代码中访问
